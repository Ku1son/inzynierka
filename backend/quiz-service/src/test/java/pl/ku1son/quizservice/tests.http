### =========================================
### GET RAW QUIZ
### Pobranie quizu bez pytań i odpowiedzi
### =========================================
GET http://localhost:8080/quizzes/1/raw


### =========================================
### GET WHOLE QUIZ
### Pobranie pełnego quizu z pytaniami i odpowiedziami
### =========================================
GET http://localhost:8080/quizzes/1


### =========================================
### UPDATE WHOLE QUIZ
### Edycja całego quizu
### =========================================
PUT http://localhost:8080/quizzes/1
Content-Type: application/json

{
  "title": "Updated Java Quiz",
  "questions": [
    {
      "content": "What does JDK mean?",
      "answers": [
        {
          "content": "Java Development Kit",
          "correct": true
        },
        {
          "content": "Java Deployment Kernel",
          "correct": false
        }
      ]
    }
  ]
}


### =========================================
### PATCH QUIZ TITLE
### Zmiana tylko tytułu quizu
### =========================================

PATCH http://localhost:8080/quizzes/1
Content-Type: application/json

{
  "title": "Patched Title"
}


